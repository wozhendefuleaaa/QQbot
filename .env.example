# backend
BACKEND_PORT=3000

# mysql
MYSQL_URL=mysql://qqbot:qqbot@mysql:3306/qqbot

# redis
REDIS_URL=redis://redis:6379

# qq official platform
QQ_API_BASE=https://bots.qq.com
QQ_APP_ID=
QQ_CLIENT_SECRET=
# 可选：手工指定网关地址，不填则由 /gateway 自动获取
QQ_GATEWAY_URL=
# 默认 QQBot，也可按官方文档要求调整
QQ_AUTH_PREFIX=QQBot
# 可选：发送消息 API 模板，支持 {targetId} 占位
# 例如 https://api.sgroup.qq.com/v2/users/{targetId}/messages
QQ_MESSAGE_API_TEMPLATE=
# 可选：Gateway HTTP 查询地址（生产：https://api.sgroup.qq.com，沙箱：https://sandbox.api.sgroup.qq.com）
QQ_GATEWAY_API_BASE=https://api.sgroup.qq.com
# 必填建议：Gateway intents 位掩码（为 0 时通常收不到消息事件）
# 常用值说明：
#   1 << 0 = 1    - 公域消息事件（C2C_MESSAGE_RECEIVED）
#   1 << 1 = 2    - 群消息事件（GROUP_AT_MESSAGE_RECEIVED）
#   1 << 30 = 1073741824 - 音频事件
#   推荐值：3 (同时接收私聊和群消息)
#   注意：私域机器人可能需要更多权限，请参考 QQ 开放平台文档
QQ_GATEWAY_INTENTS=3

# jwt authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# admin password (optional, default: admin123)
# 首次登录使用此密码，登录后强制要求修改
ADMIN_PASSWORD=admin123

# data directory (optional, default: ./backend/data)
# 用于存储用户数据、配置等持久化文件
DATA_DIR=./data
