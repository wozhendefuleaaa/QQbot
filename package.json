{
  "name": "qqbot-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "webui"
  ],
  "scripts": {
    "dev": "npm run dev -w backend",
    "dev:backend": "npm run dev -w backend",
    "dev:webui": "npm run dev -w webui",
    "dev:all": "concurrently \"npm run dev -w backend\" \"npm run dev -w webui\"",
    "build": "npm run build -w backend && npm run build -w webui",
    "start": "node backend/dist/index.js",
    "start:webui": "serve webui/dist -l 5173",
    "lint": "eslint 'backend/src/**/*.{ts,tsx}' 'webui/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'backend/src/**/*.ts' 'webui/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'backend/src/**/*.ts' 'webui/src/**/*.{ts,tsx}'"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
